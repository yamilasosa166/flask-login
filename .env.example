# Copiar a .env y completar valores reales antes de `docker compose up`.

# Flask
SECRET_KEY=cambia-esto-por-un-string-aleatorio-largo

# Postgres
POSTGRES_USER=flask
POSTGRES_PASSWORD=flask
POSTGRES_DB=flaskdb

# Puertos host (cambiar si colisionan en tu maquina)
WEB_PORT=5000
DB_PORT=5432
ADMINER_PORT=8080

# Datos del negocio (aparece en ticket de venta)
STORE_NAME=Mi Negocio

# Email (Mailpit dev — cambiar en prod por SMTP real)
MAILPIT_PORT=8025
MAIL_DEFAULT_SENDER=sistema@stock.local
APP_BASE_URL=http://localhost:5000
